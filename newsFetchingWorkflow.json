    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const rawText = $json.output;\n\nif (!rawText || rawText.trim() === \"\") {\n  return { json: buildErrorResult() };\n}\n\nlet aiData;\ntry {\n  let jsonData = JSON.parse(rawText);\n  if (Array.isArray(jsonData)) {\n    aiData = jsonData[0];\n    if (aiData.output) {\n      aiData = JSON.parse(aiData.output);\n    }\n  } else if (jsonData.output) {\n    aiData = JSON.parse(jsonData.output);\n  } else {\n    aiData = jsonData;\n  }\n} \ncatch (err) {\n  return { json: buildErrorResult(err.message) };\n}\n\nlet companyData = buildBaseResult(aiData);\nlet { errors, status } = validateCompanyData(companyData);\n\nlet result = buildResult(companyData, errors, status);\n\nreturn {\n  json: result\n};\n\nfunction buildErrorResult(errorMessage) {\n  return {\n    name: 'Unknown',\n    shortSummary: 'Unknown',\n    detailedSummary: 'Unknown',\n    lastUpdate: new Date().toISOString(),\n    pubDate: 'Unknown',\n    errorMessage: errorMessage,\n    isValid: \"invalidData\",\n    errors: [\"ERROR PARSING DATA\"]\n  };\n}\n\nfunction buildBaseResult(aiData) {\n  return {\n    name: aiData.name || 'Unknown',\n    shortSummary: aiData.shortSummary || 'Unknown',\n    detailedSummary: aiData.detailedSummary || 'Unknown',\n    pubDate: aiData.pubDate || 'Unknown',\n    lastUpdate: new Date().toISOString() \n  }\n}\n\nfunction buildResult(companyData, errors, status) {\n  return {\n    ...companyData,\n    errors: errors,\n    isValid: status\n  }\n}\n\nfunction validateCompanyData(companyData) {\n  let errors = [];\n  let status;\n\n  if (companyData.name === \"Unknown\") errors.push(`INVALID name`);\n  if (companyData.shortSummary=== \"Unknown\") errors.push(`INVALID `);\n  if (companyData.detailedSummary=== \"Unknown\") errors.push(`INVALID `);\n  if (companyData.pubDate === \"Unknown\") errors.push('INVALID pubDate')\n  if (\n    companyData.name === \"Unknown\" ||\n    companyData.shortSummary=== \"Unknown\" ||\n    companyData.detailedSummary=== \"Unknown\"\n  ) {\n    status = \"invalidData\"\n  } else if (companyData.pubDate === \"Unknown\") {\n    status = \"pubDateIsMissing\"\n  } else {\n    status = \"validData\";\n  }\n\n  return { errors, status };\n}"
      },
