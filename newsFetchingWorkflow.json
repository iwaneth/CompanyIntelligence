    {
      "parameters": {
        "jsCode": "const item = $input.item.json;\n\nconst companyName = $('loopOverItems').item.json['Company Name'] || \"Unknown\";\n\nlet newsItems = [];\n\nif (item.rss && item.rss.channel && item.rss.channel.item) {\n  newsItems = item.rss.channel.item;\n  if (!Array.isArray(newsItems)) {\n    newsItems = [newsItems];\n  }\n}\n\nif (newsItems.length === 0) {\n  return [{\n    json: {\n      error: true,\n      status: \"failed\",\n      data: \"No news found.\",\n      \"Company Name\": companyName\n    }\n  }];\n}\n\nconst cleanText = (text) => {\n  if (!text) return \"\";\n  return String(text).replace(/<[^>]*>/g, \"\").trim();\n};\n\nconst topNews = newsItems.slice(0, 5);\n\nconst mergedNewsText = topNews.map((newsItem, index) => {\n  return `Article ${index + 1}:\nTitle: ${cleanText(newsItem.title)}\nDescription: ${cleanText(newsItem.description)}\nDate: ${newsItem.pubDate?._ || newsItem.pubDate || \"Unknown\"}`;\n}).join('\\n\\n---\\n\\n');\n\nreturn [{\n  json: {\n    error: false,\n    status: \"success\",\n    data: mergedNewsText,\n    \"Company Name\": companyName\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -128,
        976
      ],
      "id": "85c025c0-df74-4580-84a8-2a3f891e638a",
