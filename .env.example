# Environment Variables Reference
# This file shows which environment variables and credentials are needed
# For n8n, credentials are configured through the UI (Settings > Credentials), not through .env
# This file is for documentation purposes only

# ============================================
# API KEYS & CREDENTIALS (Configure in n8n UI)
# ============================================

# Groq API
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API
GOOGLE_GEMINI_API_KEY=your_google_gemini_api_key_here

# Alternative AI Models (if using other providers)
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here

# NocoDB Configuration
NOCODB_API_TOKEN=your_nocodb_api_token_here
NOCODB_BASE_URL=http://nocodb:8080

# Discord Webhook (for notifications)
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# ============================================
# n8n Configuration (Optional)
# ============================================

# n8n Host and Port
N8N_HOST=localhost
N8N_PORT=5678

# Security
N8N_SECURE_COOKIE=false  # Set to true in production with HTTPS

# Encryption Key (for sensitive data - n8n generates one by default)
# N8N_ENCRYPTION_KEY=your_encryption_key_here

# ============================================
# Docker Environment
# ============================================

# Node.js environment
NODE_ENV=production

# ============================================
# IMPORTANT NOTES
# ============================================

# 1. DO NOT commit this file with actual values
# 2. This is a template showing required credentials
# 3. Actual credentials should be configured through:
#    - n8n UI (Recommended): http://localhost:5678 → Settings → Credentials
#    - Docker environment variables (Advanced)
# 4. Never expose this file with real secrets to version control
# 5. The .gitignore already excludes .env files
